{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/SamuraiWriter7/solar-system-balance-protocol/main/schemas/solar-core-state.schema.json",
  "title": "Solar Core State Record",
  "description": "Records the current strength, scope, rationale, and reversibility of central coordination across a distributed multi-agent system.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "record_id",
    "created_at",
    "system",
    "solar_core_state",
    "trigger_context",
    "reversibility",
    "trace"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "record_type": {
      "const": "solar_core_state"
    },
    "record_id": {
      "type": "string",
      "pattern": "^scs-[a-z0-9][a-z0-9._-]{2,127}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "system": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "system_id",
        "environment"
      ],
      "properties": {
        "system_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "system_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "environment": {
          "type": "string",
          "enum": [
            "development",
            "staging",
            "production",
            "simulation",
            "other"
          ]
        },
        "observation_window": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "started_at",
            "ended_at"
          ],
          "properties": {
            "started_at": {
              "type": "string",
              "format": "date-time"
            },
            "ended_at": {
              "type": "string",
              "format": "date-time"
            }
          }
        }
      }
    },
    "solar_core_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "axes",
        "aggregate_breathing_index",
        "distributed_autonomy_floor",
        "centrality_scope"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "near_distributed",
            "weak_coordination",
            "balanced",
            "strong_coordination",
            "emergency"
          ]
        },
        "axes": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "coordination_strength",
            "audit_strength",
            "routing_strength",
            "resource_control",
            "emergency_authority"
          ],
          "properties": {
            "coordination_strength": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "audit_strength": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "routing_strength": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "resource_control": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "emergency_authority": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        },
        "aggregate_breathing_index": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "value",
            "method",
            "weights"
          ],
          "properties": {
            "value": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "method": {
              "const": "weighted_mean"
            },
            "weights": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "coordination_strength",
                "audit_strength",
                "routing_strength",
                "resource_control",
                "emergency_authority"
              ],
              "properties": {
                "coordination_strength": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                },
                "audit_strength": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                },
                "routing_strength": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                },
                "resource_control": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                },
                "emergency_authority": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                }
              }
            }
          }
        },
        "distributed_autonomy_floor": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Minimum autonomy that must remain outside the core even when central coordination increases."
        },
        "centrality_scope": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "strengthened_functions",
            "preserved_distributed_functions",
            "restricted_functions"
          ],
          "properties": {
            "strengthened_functions": {
              "type": "array",
              "uniqueItems": true,
              "maxItems": 64,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "preserved_distributed_functions": {
              "type": "array",
              "uniqueItems": true,
              "maxItems": 64,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "restricted_functions": {
              "type": "array",
              "uniqueItems": true,
              "maxItems": 64,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "trigger_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "active_triggers",
        "summary",
        "evidence_refs"
      ],
      "properties": {
        "active_triggers": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "load",
              "risk",
              "innovation",
              "crisis",
              "stagnation",
              "manual",
              "other"
            ]
          }
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "evidence_refs": {
          "type": "array",
          "uniqueItems": true,
          "maxItems": 128,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512
          }
        }
      }
    },
    "reversibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reversible",
        "no_permanent_emergency_gravity",
        "return_conditions",
        "human_review_required"
      ],
      "properties": {
        "reversible": {
          "type": "boolean"
        },
        "no_permanent_emergency_gravity": {
          "const": true
        },
        "expires_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "return_target_record_id": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^scs-[a-z0-9][a-z0-9._-]{2,127}$"
        },
        "return_conditions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "maxItems": 64,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          }
        },
        "human_review_required": {
          "type": "boolean"
        },
        "review_status": {
          "type": "string",
          "enum": [
            "not_required",
            "pending",
            "approved",
            "rejected"
          ]
        }
      }
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "parent_record_ids",
        "related_protocols",
        "decision_authority"
      ],
      "properties": {
        "parent_record_ids": {
          "type": "array",
          "uniqueItems": true,
          "maxItems": 64,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          }
        },
        "related_protocols": {
          "type": "array",
          "uniqueItems": true,
          "maxItems": 64,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          }
        },
        "decision_authority": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "notes": {
          "type": "string",
          "maxLength": 4000
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "solar_core_state": {
            "properties": {
              "mode": {
                "const": "emergency"
              }
            },
            "required": [
              "mode"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "reversibility": {
            "required": [
              "expires_at",
              "review_status"
            ],
            "properties": {
              "reversible": {
                "const": true
              },
              "expires_at": {
                "type": "string",
                "format": "date-time"
              },
              "human_review_required": {
                "const": true
              },
              "review_status": {
                "enum": [
                  "pending",
                  "approved"
                ]
              }
            }
          }
        }
      }
    }
  ]
}
